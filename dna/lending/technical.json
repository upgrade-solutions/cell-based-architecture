{
  "environments": [
    {
      "name": "dev",
      "description": "Local and CI development environment."
    },
    {
      "name": "prod",
      "description": "Production environment serving live traffic."
    }
  ],
  "providers": [
    {
      "name": "aws",
      "type": "cloud",
      "region": "us-east-1",
      "description": "Primary cloud provider for compute, storage, and networking.",
      "config": {
        "account_id": "123456789012"
      }
    }
  ],
  "constructs": [
    {
      "name": "primary-db",
      "category": "storage",
      "type": "database",
      "provider": "aws",
      "description": "Primary Postgres database for all lending domain data.",
      "config": {
        "engine": "postgres",
        "version": "15",
        "instance_class": "db.t3.medium"
      }
    },
    {
      "name": "primary-db",
      "category": "storage",
      "type": "database",
      "provider": "aws",
      "environment": "dev",
      "description": "Dev database — smaller instance.",
      "config": {
        "engine": "postgres",
        "version": "15",
        "instance_class": "db.t3.micro"
      }
    }
  ],
  "variables": [
    {
      "name": "DATABASE_URL",
      "source": "secret",
      "description": "Postgres connection string for the primary database.",
      "required": true
    },
    {
      "name": "RAILS_ENV",
      "source": "literal",
      "value": "development",
      "environment": "dev",
      "required": false
    },
    {
      "name": "RAILS_ENV",
      "source": "literal",
      "value": "production",
      "environment": "prod",
      "required": false
    },
    {
      "name": "VITE_API_URL",
      "source": "output",
      "value": "api-cell-rails.api_url",
      "description": "API base URL injected into the React UI at build time.",
      "required": true
    }
  ],
  "profiles": {
    "default": [
      "api-cell-rails",
      "ui-cell"
    ]
  },
  "cells": [
    {
      "name": "api-cell-rails",
      "description": "Reads Product API DNA and generates a Rails API-mode application with controllers, models, and migrations.",
      "dna": "lending/product.api",
      "adapter": {
        "type": "ruby/rails",
        "config": {
          "operational_dna": "lending/operational",
          "port": 3000
        }
      },
      "constructs": [
        "primary-db"
      ],
      "variables": [
        {
          "name": "DATABASE_URL",
          "source": "secret",
          "required": true
        },
        {
          "name": "RAILS_ENV",
          "source": "env",
          "required": false
        }
      ],
      "outputs": [
        {
          "name": "api_url",
          "cell": "api-cell-rails",
          "value": "http://localhost:3000"
        }
      ]
    },
    {
      "name": "ui-cell",
      "description": "Reads Product UI DNA and produces the Vite + React loan dashboard.",
      "dna": "lending/product.ui",
      "adapter": {
        "type": "vite/react",
        "version": "5",
        "config": {
          "operational_dna": "lending/operational",
          "api_dna": "lending/product.api",
          "api_base": "http://localhost:3000"
        }
      },
      "constructs": [],
      "variables": [
        {
          "name": "VITE_API_URL",
          "source": "output",
          "value": "api-cell-rails.api_url",
          "required": true
        }
      ]
    }
  ],
  "views": [
    {
      "name": "deployment",
      "description": "Cell deployment topology — Rails API, React UI, Postgres DB.",
      "layout": {
        "type": "hierarchical",
        "direction": "TB"
      },
      "nodes": [
        {
          "id": "api-cell-rails",
          "name": "API Cell (Rails)",
          "type": "cell",
          "status": "planned",
          "source": "technical:cell:api-cell-rails",
          "position": { "x": 100, "y": 160 },
          "metadata": { "adapter": "ruby/rails" }
        },
        {
          "id": "ui-cell",
          "name": "UI Cell (React)",
          "type": "cell",
          "status": "planned",
          "source": "technical:cell:ui-cell",
          "position": { "x": 500, "y": 160 },
          "metadata": { "adapter": "vite/react" }
        },
        {
          "id": "primary-db",
          "name": "Primary DB",
          "type": "construct",
          "status": "planned",
          "source": "technical:construct:primary-db",
          "position": { "x": 100, "y": 480 },
          "metadata": { "category": "storage", "engine": "postgres" }
        }
      ],
      "connections": [
        {
          "id": "rails-to-db",
          "source": "api-cell-rails",
          "target": "primary-db",
          "type": "depends-on",
          "label": "reads/writes"
        },
        {
          "id": "ui-to-rails",
          "source": "ui-cell",
          "target": "api-cell-rails",
          "type": "communicates-with",
          "label": "REST"
        }
      ],
      "zones": [
        {
          "id": "compute-tier",
          "name": "Compute",
          "type": "tier",
          "nodes": ["api-cell-rails", "ui-cell"],
          "description": "Application cells."
        },
        {
          "id": "storage-tier",
          "name": "Storage",
          "type": "tier",
          "nodes": ["primary-db"],
          "description": "Database cell and construct."
        }
      ]
    }
  ]
}
