{
  "environments": [
    {
      "name": "dev",
      "description": "Local and CI development environment."
    },
    {
      "name": "prod",
      "description": "Production environment serving live traffic."
    }
  ],
  "providers": [
    {
      "name": "aws",
      "type": "cloud",
      "region": "us-east-1",
      "description": "Primary cloud provider for compute, storage, and networking.",
      "config": {
        "account_id": "123456789012"
      }
    },
    {
      "name": "auth0",
      "type": "auth",
      "description": "Identity provider for authentication and role-based access control.",
      "config": {
        "domain": "acme.auth0.com",
        "audience": "https://api.acme.finance",
        "roleClaim": "https://acme.finance/roles"
      }
    }
  ],
  "constructs": [
    {
      "name": "primary-db",
      "category": "storage",
      "type": "database",
      "provider": "aws",
      "description": "Primary Postgres database for all lending domain data.",
      "config": {
        "engine": "postgres",
        "version": "15",
        "instance_class": "db.t3.medium"
      }
    },
    {
      "name": "primary-db",
      "category": "storage",
      "type": "database",
      "provider": "aws",
      "environment": "dev",
      "description": "Dev database — smaller instance.",
      "config": {
        "engine": "postgres",
        "version": "15",
        "instance_class": "db.t3.micro"
      }
    },
    {
      "name": "session-cache",
      "category": "storage",
      "type": "cache",
      "provider": "aws",
      "description": "Redis cache for session state and short-lived tokens.",
      "config": {
        "engine": "redis",
        "version": "7"
      }
    },
    {
      "name": "auth-provider",
      "category": "storage",
      "type": "database",
      "provider": "auth0",
      "description": "Auth0 tenant providing JWT issuance and role management."
    },
    {
      "name": "api-gateway",
      "category": "network",
      "type": "gateway",
      "provider": "aws",
      "description": "AWS API Gateway fronting the API server.",
      "config": {
        "type": "HTTP"
      }
    },
    {
      "name": "api-server",
      "category": "compute",
      "type": "container",
      "provider": "aws",
      "description": "ECS Fargate container running the NestJS API.",
      "config": {
        "cpu": 512,
        "memory": 1024,
        "port": 3000
      }
    },
    {
      "name": "api-server",
      "category": "compute",
      "type": "container",
      "provider": "aws",
      "environment": "dev",
      "description": "Dev API server — minimal resources.",
      "config": {
        "cpu": 256,
        "memory": 512,
        "port": 3000
      }
    },
    {
      "name": "ui-server",
      "category": "compute",
      "type": "container",
      "provider": "aws",
      "description": "ECS Fargate container running the Next.js UI.",
      "config": {
        "cpu": 256,
        "memory": 512,
        "port": 3001
      }
    }
  ],
  "variables": [
    {
      "name": "DATABASE_URL",
      "source": "secret",
      "description": "Postgres connection string for the primary database.",
      "required": true
    },
    {
      "name": "REDIS_URL",
      "source": "secret",
      "description": "Redis connection URL for the session cache.",
      "required": true
    },
    {
      "name": "AUTH0_DOMAIN",
      "source": "secret",
      "description": "Auth0 domain for JWT verification.",
      "required": true
    },
    {
      "name": "AUTH0_AUDIENCE",
      "source": "literal",
      "value": "https://api.acme.finance",
      "description": "Expected JWT audience claim.",
      "required": true
    },
    {
      "name": "AUTH0_CLIENT_ID",
      "source": "secret",
      "description": "Auth0 client ID for the API.",
      "required": true
    },
    {
      "name": "AUTH0_CLIENT_SECRET",
      "source": "secret",
      "description": "Auth0 client secret for the API.",
      "required": true
    },
    {
      "name": "NEXT_PUBLIC_API_URL",
      "source": "output",
      "value": "api-cell.api_url",
      "description": "Public API base URL injected into the Next.js UI at build time.",
      "required": true
    },
    {
      "name": "NODE_ENV",
      "source": "literal",
      "value": "development",
      "environment": "dev",
      "required": false
    },
    {
      "name": "NODE_ENV",
      "source": "literal",
      "value": "production",
      "environment": "prod",
      "required": false
    }
  ],
  "profiles": {
    "express-stack": [
      "api-cell",
      "db-cell",
      "ui-cell"
    ],
    "nestjs-stack": [
      "api-cell-nestjs",
      "db-cell",
      "ui-cell"
    ],
    "rails-stack": [
      "api-cell-rails",
      "db-cell",
      "ui-cell"
    ],
    "python-stack": [
      "api-cell-fastapi",
      "db-cell",
      "ui-cell"
    ],
    "full": [
      "api-cell",
      "api-cell-nestjs",
      "api-cell-rails",
      "api-cell-fastapi",
      "db-cell",
      "ui-cell",
      "vue-ui-cell",
      "ui-cell-next"
    ]
  },
  "cells": [
    {
      "name": "api-cell",
      "description": "Reads Product API DNA and runs a dynamic Express API — routes and OpenAPI spec are interpreted from DNA at startup.",
      "dna": "lending/product.api",
      "adapter": {
        "type": "node/express",
        "config": {
          "operational_dna": "lending/operational"
        }
      },
      "constructs": [
        "primary-db",
        "session-cache",
        "auth-provider",
        "api-gateway",
        "api-server"
      ],
      "variables": [
        {
          "name": "DATABASE_URL",
          "source": "secret",
          "required": true
        },
        {
          "name": "REDIS_URL",
          "source": "secret",
          "required": true
        },
        {
          "name": "AUTH0_DOMAIN",
          "source": "secret",
          "required": true
        },
        {
          "name": "AUTH0_AUDIENCE",
          "source": "literal",
          "value": "https://api.acme.finance",
          "required": true
        },
        {
          "name": "AUTH0_CLIENT_ID",
          "source": "secret",
          "required": true
        },
        {
          "name": "AUTH0_CLIENT_SECRET",
          "source": "secret",
          "required": true
        },
        {
          "name": "NODE_ENV",
          "source": "env",
          "required": false
        }
      ],
      "outputs": [
        {
          "name": "api_url",
          "cell": "api-cell",
          "value": "api-gateway.url"
        }
      ]
    },
    {
      "name": "api-cell-nestjs",
      "description": "Reads Product API DNA and generates a NestJS API with static typed controllers, services, and DTOs.",
      "dna": "lending/product.api",
      "adapter": {
        "type": "node/nestjs",
        "config": {
          "operational_dna": "lending/operational"
        }
      },
      "constructs": [
        "primary-db",
        "session-cache",
        "auth-provider",
        "api-gateway",
        "api-server"
      ],
      "variables": [
        {
          "name": "DATABASE_URL",
          "source": "secret",
          "required": true
        },
        {
          "name": "REDIS_URL",
          "source": "secret",
          "required": true
        },
        {
          "name": "AUTH0_DOMAIN",
          "source": "secret",
          "required": true
        },
        {
          "name": "AUTH0_AUDIENCE",
          "source": "literal",
          "value": "https://api.acme.finance",
          "required": true
        },
        {
          "name": "AUTH0_CLIENT_ID",
          "source": "secret",
          "required": true
        },
        {
          "name": "AUTH0_CLIENT_SECRET",
          "source": "secret",
          "required": true
        },
        {
          "name": "NODE_ENV",
          "source": "env",
          "required": false
        }
      ]
    },
    {
      "name": "api-cell-rails",
      "description": "Reads Product API DNA and generates a Rails API-mode application with controllers, models, and migrations.",
      "dna": "lending/product.api",
      "adapter": {
        "type": "ruby/rails",
        "config": {
          "operational_dna": "lending/operational",
          "port": 3002
        }
      },
      "constructs": [
        "primary-db",
        "session-cache",
        "auth-provider",
        "api-gateway",
        "api-server"
      ],
      "variables": [
        {
          "name": "DATABASE_URL",
          "source": "secret",
          "required": true
        },
        {
          "name": "AUTH0_DOMAIN",
          "source": "secret",
          "required": true
        },
        {
          "name": "AUTH0_AUDIENCE",
          "source": "literal",
          "value": "https://api.acme.finance",
          "required": true
        }
      ]
    },
    {
      "name": "api-cell-fastapi",
      "description": "Reads Product API DNA and generates a FastAPI application with typed routers, Pydantic schemas, and SQLAlchemy models.",
      "dna": "lending/product.api",
      "adapter": {
        "type": "python/fastapi",
        "config": {
          "operational_dna": "lending/operational",
          "port": 8000
        }
      },
      "constructs": [
        "primary-db",
        "session-cache",
        "auth-provider",
        "api-gateway",
        "api-server"
      ],
      "variables": [
        {
          "name": "DATABASE_URL",
          "source": "secret",
          "required": true
        },
        {
          "name": "AUTH0_DOMAIN",
          "source": "secret",
          "required": true
        },
        {
          "name": "AUTH0_AUDIENCE",
          "source": "literal",
          "value": "https://api.acme.finance",
          "required": true
        }
      ]
    },
    {
      "name": "db-cell",
      "description": "Provisions the Postgres database and lending_app role (infra-only — schema is owned by api-cell).",
      "dna": "lending/operational",
      "adapter": {
        "type": "postgres",
        "config": {
          "construct": "primary-db",
          "database": "lending",
          "app_role": "lending_app",
          "port": 5433
        }
      },
      "constructs": [
        "primary-db"
      ],
      "variables": [
        {
          "name": "DATABASE_URL",
          "source": "secret",
          "required": true
        }
      ]
    },
    {
      "name": "ui-cell",
      "description": "Reads Product UI DNA and produces the Vite + React loan dashboard.",
      "dna": "lending/product.ui",
      "adapter": {
        "type": "vite/react",
        "version": "5",
        "config": {
          "operational_dna": "lending/operational",
          "api_dna": "lending/product.api",
          "api_base": "http://localhost:3001"
        }
      },
      "constructs": [
        "auth-provider",
        "ui-server"
      ],
      "variables": [
        {
          "name": "AUTH0_DOMAIN",
          "source": "secret",
          "required": true
        },
        {
          "name": "AUTH0_CLIENT_ID",
          "source": "secret",
          "required": true
        },
        {
          "name": "AUTH0_CLIENT_SECRET",
          "source": "secret",
          "required": true
        },
        {
          "name": "NEXT_PUBLIC_API_URL",
          "source": "output",
          "value": "api-cell.api_url",
          "required": true
        },
        {
          "name": "NODE_ENV",
          "source": "env",
          "required": false
        }
      ]
    },
    {
      "name": "vue-ui-cell",
      "description": "Reads Product UI DNA and produces the Vite + Vue loan dashboard.",
      "dna": "lending/product.ui",
      "adapter": {
        "type": "vite/vue",
        "version": "5",
        "config": {
          "operational_dna": "lending/operational",
          "api_dna": "lending/product.api",
          "api_base": "http://localhost:3001"
        }
      },
      "constructs": [
        "auth-provider",
        "ui-server"
      ],
      "variables": [
        {
          "name": "AUTH0_DOMAIN",
          "source": "secret",
          "required": true
        },
        {
          "name": "AUTH0_CLIENT_ID",
          "source": "secret",
          "required": true
        },
        {
          "name": "AUTH0_CLIENT_SECRET",
          "source": "secret",
          "required": true
        },
        {
          "name": "NEXT_PUBLIC_API_URL",
          "source": "output",
          "value": "api-cell.api_url",
          "required": true
        },
        {
          "name": "NODE_ENV",
          "source": "env",
          "required": false
        }
      ]
    },
    {
      "name": "ui-cell-next",
      "description": "Reads Product UI DNA and produces a Next.js App Router loan dashboard with SSR.",
      "dna": "lending/product.ui",
      "adapter": {
        "type": "next/react",
        "version": "14",
        "config": {
          "operational_dna": "lending/operational",
          "api_dna": "lending/product.api",
          "api_base": "http://localhost:3001"
        }
      },
      "constructs": [
        "auth-provider",
        "ui-server"
      ],
      "variables": [
        {
          "name": "AUTH0_DOMAIN",
          "source": "secret",
          "required": true
        },
        {
          "name": "AUTH0_CLIENT_ID",
          "source": "secret",
          "required": true
        },
        {
          "name": "AUTH0_CLIENT_SECRET",
          "source": "secret",
          "required": true
        },
        {
          "name": "NEXT_PUBLIC_API_URL",
          "source": "output",
          "value": "api-cell.api_url",
          "required": true
        },
        {
          "name": "NODE_ENV",
          "source": "env",
          "required": false
        }
      ]
    }
  ],
