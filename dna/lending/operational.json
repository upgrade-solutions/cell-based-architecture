  "tasks": [
    {
      "name": "review-loan",
      "description": "Underwriter picks up a loan application from the queue and reviews it.",
      "position": "Underwriter",
      "capability": "Loan.Review",
      "domain": "acme.finance.lending"
    },
    {
      "name": "approve-loan",
      "description": "Underwriter approves the loan and locks in terms.",
      "position": "Underwriter",
      "capability": "Loan.Approve",
      "domain": "acme.finance.lending"
    },
    {
      "name": "reject-loan",
      "description": "Underwriter rejects the loan application.",
      "position": "Underwriter",
      "capability": "Loan.Reject",
      "domain": "acme.finance.lending"
    },
    {
      "name": "suspend-borrower",
      "description": "Manager suspends a borrower account to prevent new applications.",
      "position": "LendingManager",
      "capability": "Borrower.Suspend",
      "domain": "acme.finance.lending"
    },
    {
      "name": "onboard-lender",
      "description": "Admin adds a new lender to the platform.",
      "position": "LenderAdmin",
      "capability": "Lender.Onboard",
      "domain": "acme.finance.lending"
    },
    {
      "name": "activate-lender",
      "description": "Admin authorizes a lender to fund new loans.",
      "position": "LenderAdmin",
      "capability": "Lender.Activate",
      "domain": "acme.finance.lending"
    },
    {
      "name": "deactivate-lender",
      "description": "Admin pauses a lender from funding new loans.",
      "position": "LenderAdmin",
      "capability": "Lender.Deactivate",
      "domain": "acme.finance.lending"
    },
    {
      "name": "update-lender-rates",
      "description": "Admin updates a lender's posted interest rate schedule.",
      "position": "LenderAdmin",
      "capability": "Lender.UpdateRates",
      "domain": "acme.finance.lending"
    }
  ],
  "processes": [
    {
      "name": "LoanOrigination",
      "description": "Staff workflow for processing a loan application through underwriting to a decision. Begins after a borrower self-submits an application (Loan.Apply) and ends with approval or rejection. Disbursement is system-triggered after approval.",
      "domain": "acme.finance.lending",
      "operator": "LendingManager",
      "steps": [
        {
          "id": "review",
          "task": "review-loan",
          "description": "Underwriter picks up the application from the queue."
        },
        {
          "id": "approve",
          "task": "approve-loan",
          "depends_on": ["review"],
          "branch": { "when": "loan qualifies per underwriting criteria", "else": "reject" },
          "description": "If the loan qualifies, underwriter approves and locks terms."
        },
        {
          "id": "reject",
          "task": "reject-loan",
          "depends_on": ["review"],
          "description": "If the loan does not qualify, underwriter rejects the application."
        }
      ]
    },
    {
      "name": "LenderOnboarding",
      "description": "Staff workflow for adding a new lending partner to the platform.",
      "domain": "acme.finance.lending",
      "operator": "LendingManager",
      "steps": [
        {
          "id": "onboard",
          "task": "onboard-lender",
          "description": "Admin registers the lender entity with license and jurisdiction details."
        },
        {
          "id": "activate",
          "task": "activate-lender",
          "depends_on": ["onboard"],
          "description": "Admin activates the lender to begin funding loans."
        }
      ]
    }
  ],
