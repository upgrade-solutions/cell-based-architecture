                ]
              }
            ],
            "roles": [
              {
                "name": "BorrowerActor"
              },
              {
                "name": "Admin"
              },
              {
                "name": "Underwriter"
              },
              {
                "name": "System"
              },
              {
                "name": "LendingManager"
              },
              {
                "name": "LenderAdmin"
              }
            ]
          }
        ]
      }
    ]
  },
  "operations": [
    {
      "name": "Borrower.Register",
      "target": "Borrower",
      "action": "Register",
      "description": "A new borrower creates their profile in the system."
    },
    {
      "name": "Borrower.Suspend",
      "target": "Borrower",
      "action": "Suspend",
      "description": "An admin suspends a borrower, preventing new applications.",
      "changes": [
        {
          "attribute": "borrower.status",
          "set": "suspended"
        }
      ]
    },
    {
      "name": "Loan.Apply",
      "target": "Loan",
      "action": "Apply",
      "description": "A borrower submits a loan application.",
      "changes": [
        {
          "attribute": "loan.status",
          "set": "under_review"
        }
      ]
    },
    {
      "name": "Loan.Review",
      "target": "Loan",
      "action": "Review",
      "description": "An underwriter picks up an application for review."
    },
    {
      "name": "Loan.Approve",
      "target": "Loan",
      "action": "Approve",
      "description": "An underwriter approves the loan and sets terms.",
      "changes": [
        {
          "attribute": "loan.status",
          "set": "approved"
        },
        {
          "attribute": "loan.approved_at",
          "set": "now"
        },
        {
          "attribute": "loan.reviewed_by",
          "set": "actor.id"
        }
      ]
    },
    {
      "name": "Loan.Reject",
      "target": "Loan",
      "action": "Reject",
      "description": "An underwriter rejects the loan application.",
      "changes": [
        {
          "attribute": "loan.status",
          "set": "rejected"
        }
      ]
    },
    {
      "name": "Loan.Disburse",
      "target": "Loan",
      "action": "Disburse",
      "description": "Funds are disbursed to the borrower.",
      "changes": [
        {
          "attribute": "loan.status",
          "set": "active"
        },
        {
          "attribute": "loan.disbursed_at",
          "set": "now"
        },
        {
          "attribute": "loan.amount_paid",
          "set": 0
        }
      ]
    },
    {
      "name": "Loan.Repay",
      "target": "Loan",
      "action": "Repay",
      "description": "A borrower submits a repayment.",
      "changes": [
        {
          "attribute": "loan.amount_paid",
          "set": "loan.amount_paid + input.payment_amount"
        }
      ]
    },
    {
      "name": "Loan.Default",
      "target": "Loan",
      "action": "Default",
      "description": "The loan is marked as defaulted after passing its due date unpaid.",
      "changes": [
        {
          "attribute": "loan.status",
          "set": "defaulted"
        }
      ]
    },
    {
      "name": "Lender.Onboard",
      "target": "Lender",
      "action": "Onboard",
      "description": "A new lender is added to the platform."
    },
    {
      "name": "Lender.Activate",
      "target": "Lender",
      "action": "Activate",
      "description": "A lender is authorized to fund new loans."
    },
    {
      "name": "Lender.Deactivate",
      "target": "Lender",
      "action": "Deactivate",
      "description": "A lender is paused from funding new loans."
    },
    {
      "name": "Lender.UpdateRates",
      "target": "Lender",
      "action": "UpdateRates",
      "description": "A lender updates their posted interest rate schedule."
    },
    {
      "name": "Borrower.View",
      "target": "Borrower",
      "action": "View"
    },
    {
      "name": "Borrower.List",
      "target": "Borrower",
      "action": "List"
    },
    {
      "name": "Loan.View",
      "target": "Loan",
      "action": "View"
    },
    {
      "name": "Loan.List",
      "target": "Loan",
      "action": "List"
    },
    {
      "name": "Lender.View",
      "target": "Lender",
      "action": "View"
    },
    {
      "name": "Lender.List",
      "target": "Lender",
      "action": "List"
    }
  ],
  "triggers": [
    {
      "source": "user",
      "operation": "Borrower.Register",
      "description": "Borrower submits a registration form."
    },
    {
      "source": "user",
      "operation": "Borrower.Suspend",
      "description": "An admin manually suspends the borrower."
    },
    {
      "source": "user",
      "operation": "Loan.Apply",
      "description": "Borrower submits the loan application form."
    },
    {
      "source": "operation",
      "operation": "Loan.Review",
      "description": "Application enters the underwriting queue automatically after submission.",
      "after": "Loan.Apply"
    },
    {
      "source": "user",
      "operation": "Loan.Approve",
      "description": "Underwriter approves the application from the review queue."
    },
    {
      "source": "user",
      "operation": "Loan.Reject",
      "description": "Underwriter rejects the application from the review queue."
    },
    {
      "source": "operation",
      "operation": "Loan.Disburse",
      "description": "Disbursement is initiated automatically once a loan is approved.",
      "after": "Loan.Approve"
    },
    {
      "source": "user",
      "operation": "Loan.Repay",
      "description": "Borrower submits a repayment from their loan detail page."
    },
    {
      "source": "schedule",
      "operation": "Loan.Default",
      "description": "Daily job checks all active loans and marks overdue ones as defaulted.",
      "schedule": "0 0 * * *"
    }
  ],
  "rules": [
    {
      "type": "access",
      "description": "Any unauthenticated user can register as a borrower.",
      "allow": [
        {
          "role": "BorrowerActor"
        }
      ],
      "operation": "Borrower.Register"
    },
    {
      "type": "access",
      "description": "Only admins may suspend borrowers.",
      "allow": [
        {
          "role": "Admin"
        }
      ],
      "operation": "Borrower.Suspend"
    },
    {
      "type": "access",
      "description": "Only authenticated borrowers may apply for a loan.",
      "allow": [
        {
          "role": "BorrowerActor"
        }
      ],
      "operation": "Loan.Apply"
    },
    {
      "type": "access",
      "description": "Only underwriters may open an application for review.",
      "allow": [
        {
          "role": "Underwriter"
        }
      ],
      "operation": "Loan.Review"
    },
    {
      "type": "access",
      "description": "Only underwriters may approve a loan.",
      "allow": [
        {
          "role": "Underwriter"
        }
      ],
      "operation": "Loan.Approve"
    },
    {
      "type": "access",
      "description": "Only underwriters may reject a loan.",
      "allow": [
        {
          "role": "Underwriter"
        }
      ],
      "operation": "Loan.Reject"
    },
    {
      "type": "access",
      "description": "Disbursement is performed by the system only.",
      "allow": [
        {
          "role": "System"
        }
      ],
      "operation": "Loan.Disburse"
    },
    {
      "type": "access",
      "description": "Only the borrower who owns the loan may submit a repayment.",
      "allow": [
        {
          "role": "BorrowerActor",
          "ownership": true
        }
      ],
      "operation": "Loan.Repay"
    },
    {
      "type": "access",
      "description": "Defaulting is performed by the system scheduler only.",
      "allow": [
        {
          "role": "System"
        }
      ],
      "operation": "Loan.Default"
    },
    {
      "type": "condition",
      "description": "Borrower must have a complete financial profile before applying.",
      "conditions": [
        {
          "attribute": "borrower.credit_score",
          "operator": "present"
        },
        {
          "attribute": "borrower.annual_income",
          "operator": "present"
        },
        {
          "attribute": "borrower.status",
          "operator": "eq",
          "value": "active"
        },
        {
          "attribute": "loan.amount",
          "operator": "gt",
          "value": 0
        },
        {
          "attribute": "loan.term_months",
          "operator": "gt",
          "value": 0
        }
      ],
      "operation": "Loan.Apply"
    },
    {
      "type": "condition",
      "description": "Only loans in under_review status can be picked up by an underwriter.",
      "conditions": [
        {
          "attribute": "loan.status",
          "operator": "eq",
          "value": "under_review"
        }
      ],
      "operation": "Loan.Review"
    },
    {
      "type": "condition",
      "description": "Loan must be under review and within the lender's maximum amount.",
      "conditions": [
        {
          "attribute": "loan.status",
          "operator": "eq",
          "value": "under_review"
        },
        {
          "attribute": "loan.amount",
          "operator": "lte",
          "value": 250000
        }
      ],
      "operation": "Loan.Approve"
    },
    {
      "type": "condition",
      "description": "Only loans under review can be rejected.",
      "conditions": [
        {
          "attribute": "loan.status",
          "operator": "eq",
          "value": "under_review"
        }
      ],
      "operation": "Loan.Reject"
    },
    {
      "type": "condition",
      "description": "Only approved loans can be disbursed.",
      "conditions": [
        {
          "attribute": "loan.status",
          "operator": "eq",
          "value": "approved"
        }
      ],
      "operation": "Loan.Disburse"
    },
    {
      "type": "condition",
      "description": "Repayments can only be made on active loans.",
      "conditions": [
        {
          "attribute": "loan.status",
          "operator": "eq",
          "value": "active"
        },
        {
          "attribute": "loan.amount_paid",
          "operator": "lt",
          "value": "loan.amount"
        }
      ],
      "operation": "Loan.Repay"
    },
    {
      "type": "condition",
      "description": "Only active loans past their due date are eligible for default.",
      "conditions": [
        {
          "attribute": "loan.status",
          "operator": "eq",
          "value": "active"
        },
        {
          "attribute": "loan.due_date",
          "operator": "present"
        }
      ],
      "operation": "Loan.Default"
    }
  ],
  "tasks": [
    {
      "name": "review-loan",
      "description": "Underwriter picks up a loan application from the queue and reviews it.",
      "actor": "Underwriter",
      "operation": "Loan.Review",
      "domain": "acme.finance.lending"
    },
    {
      "name": "approve-loan",
      "description": "Underwriter approves the loan and locks in terms.",
      "actor": "Underwriter",
      "operation": "Loan.Approve",
      "domain": "acme.finance.lending"
    },
    {
      "name": "reject-loan",
      "description": "Underwriter rejects the loan application.",
      "actor": "Underwriter",
      "operation": "Loan.Reject",
      "domain": "acme.finance.lending"
    },
    {
      "name": "suspend-borrower",
      "description": "Manager suspends a borrower account to prevent new applications.",
      "actor": "LendingManager",
      "operation": "Borrower.Suspend",
      "domain": "acme.finance.lending"
    },
    {
      "name": "onboard-lender",
      "description": "Admin adds a new lender to the platform.",
      "actor": "LenderAdmin",
      "operation": "Lender.Onboard",
      "domain": "acme.finance.lending"
    },
    {
      "name": "activate-lender",
      "description": "Admin authorizes a lender to fund new loans.",
      "actor": "LenderAdmin",
      "operation": "Lender.Activate",
      "domain": "acme.finance.lending"
    },
    {
      "name": "deactivate-lender",
      "description": "Admin pauses a lender from funding new loans.",
      "actor": "LenderAdmin",
      "operation": "Lender.Deactivate",
      "domain": "acme.finance.lending"
    },
    {
      "name": "update-lender-rates",
      "description": "Admin updates a lender's posted interest rate schedule.",
      "actor": "LenderAdmin",
      "operation": "Lender.UpdateRates",
      "domain": "acme.finance.lending"
    }
  ],
  "processes": [
    {
      "name": "LoanOrigination",
      "description": "Staff workflow for processing a loan application through underwriting to a decision. Begins after a borrower self-submits an application (Loan.Apply) and ends with approval or rejection. Disbursement is system-triggered after approval.",
      "domain": "acme.finance.lending",
      "operator": "LendingManager",
      "steps": [
        {
          "id": "review",
          "task": "review-loan",
