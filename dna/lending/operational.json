{
  "domain": {
    "name": "lending",
    "path": "acme.finance.lending",
    "description": "Loan origination, underwriting, disbursement, and repayment.",
    "domains": [
      {
        "name": "finance",
        "path": "acme.finance",
        "domains": [
          {
            "name": "lending",
            "path": "acme.finance.lending",
            "description": "Loan origination, underwriting, disbursement, and repayment.",
            "resources": [
              {
                "name": "Borrower",
                "description": "A person or entity that applies for and receives a loan.",
                "attributes": [
                  {
                    "name": "id",
                    "type": "string",
                    "required": true,
                    "description": "Unique identifier."
                  },
                  {
                    "name": "first_name",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "last_name",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "email",
                    "type": "string",
                    "required": true
                  },
                  {
                    "name": "date_of_birth",
                    "type": "date"
                  },
                  {
                    "name": "annual_income",
                    "type": "number",
                    "description": "Stated annual income in base currency."
                  },
                  {
                    "name": "credit_score",
                    "type": "number",
                    "description": "Credit bureau score at time of application."
                  },
                  {
                    "name": "status",
                    "type": "enum",
                    "values": [
                      "active",
                      "suspended"
                    ],
                    "required": true
                  }
                ],
                "actions": [
                  {
                    "name": "Register",
                    "description": "A new borrower creates their profile."
                  },
                  {
                    "name": "Suspend",
                    "description": "An admin suspends a borrower account."
                  },
                  {
                    "name": "View",
                    "type": "read"
                  },
                  {
                    "name": "List",
                    "type": "read"
                  }
                ],
                "examples": [
                  {
