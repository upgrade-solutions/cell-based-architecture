                    "reviewed_by": null
                  },
                  {
                    "id": "loan-3",
                    "borrower_id": "borrower-3",
                    "lender_id": "lender-1",
                    "amount": 9000,
                    "interest_rate": 0.095,
                    "term_months": 12,
                    "purpose": "Medical expenses",
                    "status": "repaid",
                    "amount_paid": 9000,
                    "due_date": "2025-01-15",
