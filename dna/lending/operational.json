                    "annual_income": 67000,
                    "credit_score": 690,
                    "status": "active"
                  },
                  {
                    "id": "borrower-3",
                    "first_name": "Sofia",
                    "last_name": "Reyes",
                    "email": "sofia.reyes@example.com",
