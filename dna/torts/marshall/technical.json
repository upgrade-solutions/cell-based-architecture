{
  "environments": [
    {
      "name": "dev",
      "description": "Local development environment."
    },
    {
      "name": "prod",
      "description": "Production environment serving live traffic."
    }
  ],
  "providers": [
    {
      "name": "aws",
      "type": "cloud",
      "region": "us-east-1",
      "description": "Primary cloud provider."
    },
    {
      "name": "built-in",
      "type": "auth",
      "description": "Built-in JWT authentication — API issues its own tokens.",
      "config": {
        "provider": "built-in"
      }
    }
  ],
  "constructs": [
    {
      "name": "primary-db",
      "category": "storage",
      "type": "database",
      "provider": "aws",
      "description": "Primary Postgres database for all Marshall Fire mass-tort data.",
      "config": {
        "engine": "postgres",
        "version": "16",
        "instance_class": "db.t3.medium"
      }
    },
    {
      "name": "primary-db",
      "category": "storage",
      "type": "database",
      "provider": "aws",
      "environment": "dev",
      "description": "Local Postgres for Marshall Fire development.",
      "config": {
        "engine": "postgres",
        "version": "16",
        "port": 5432
      }
    },
    {
      "name": "event-bus",
      "category": "storage",
      "type": "queue",
      "provider": "aws",
      "description": "Event bus for cross-cell async Signals — EventBridge with SQS subscriber targets.",
      "config": {
        "engine": "eventbridge"
      }
    },
    {
      "name": "event-bus",
      "category": "storage",
      "type": "queue",
      "provider": "aws",
      "environment": "dev",
      "description": "Local RabbitMQ for the event bus in development.",
      "config": {
        "engine": "rabbitmq",
        "version": "3",
        "port": 5672,
        "management_port": 15672
      }
    }
  ],
  "variables": [
    {
      "name": "DATABASE_URL",
      "source": "secret",
      "description": "Postgres connection string for the Marshall primary-db.",
      "required": true
    },
    {
      "name": "EVENT_BUS_URL",
      "source": "secret",
      "description": "RabbitMQ connection URL for local development.",
      "required": false
    },
    {
      "name": "EVENT_BUS_NAME",
      "source": "secret",
      "description": "EventBridge custom bus name for prod signal publishing.",
      "required": false
    },
    {
      "name": "EVENT_BUS_QUEUE_URL",
      "source": "secret",
      "description": "SQS queue URL for prod signal subscriber polling.",
      "required": false
    }
  ],
  "profiles": {
    "default": [
      "db-cell",
      "event-bus-cell",
      "api-cell",
      "ui-cell",
      "admin-ui-cell"
    ],
    "marketing-only": [
      "ui-cell"
    ]
  },
  "views": [
    {
      "name": "deployment",
      "description": "Layout overlay for the derived deployment view — positions only. Nodes, connections, and zones are auto-derived from cells/constructs/providers.",
      "nodes": [
        { "id": "aws", "position": { "x": 600, "y": 20 }, "size": { "width": 140, "height": 50 } },
        { "id": "built-in", "position": { "x": 780, "y": 20 }, "size": { "width": 160, "height": 50 } },
        { "id": "primary-db", "position": { "x": 100, "y": 380 }, "size": { "width": 160, "height": 60 } },
        { "id": "event-bus", "position": { "x": 380, "y": 380 }, "size": { "width": 160, "height": 60 } },
        { "id": "db-cell", "position": { "x": 80, "y": 240 }, "size": { "width": 160, "height": 70 } },
        { "id": "event-bus-cell", "position": { "x": 320, "y": 240 }, "size": { "width": 180, "height": 70 } },
        { "id": "api-cell", "position": { "x": 560, "y": 180 }, "size": { "width": 160, "height": 70 } },
        { "id": "ui-cell", "position": { "x": 780, "y": 120 }, "size": { "width": 160, "height": 70 } },
        { "id": "admin-ui-cell", "position": { "x": 780, "y": 240 }, "size": { "width": 160, "height": 70 } }
      ],
      "zones": [
        { "id": "zone-compute", "position": { "x": 50, "y": 100 }, "size": { "width": 920, "height": 240 } },
        { "id": "zone-storage", "position": { "x": 50, "y": 360 }, "size": { "width": 530, "height": 100 } }
      ]
    }
  ],
  "cells": [
    {
      "name": "ui-cell",
      "description": "Marshall Fire public marketing site — Vite + React with the marketing layout.",
      "dna": "torts/marshall/product.ui",
      "adapter": {
        "type": "vite/react",
        "version": "5",
        "config": {
          "core_dna": "torts/marshall/product.core",
          "api_dna": "torts/marshall/product.api",
          "api_base": ""
        }
      },
      "constructs": [],
      "variables": []
    },
    {
      "name": "db-cell",
      "description": "Provisions the Postgres database, application role, and permissions. Schema migrations live in api-cell (drizzle).",
      "dna": "torts/marshall/product.core",
      "adapter": {
        "type": "postgres",
        "config": {
          "construct": "primary-db"
        }
      },
      "constructs": [
        "primary-db"
      ],
      "variables": []
    },
    {
      "name": "event-bus-cell",
      "description": "Reads Product Core DNA Signals (marshall.IntakeSubmission.Received, .Claimant.Qualified, .Claimant.Registered, .Claim.Filed) and generates the schema registry, typed publishers, routing config, and subscriber worker stubs.",
      "dna": "torts/marshall/product.core",
      "adapter": {
        "type": "node/event-bus",
        "config": {
          "engine": "eventbridge"
        }
      },
      "constructs": [
        "event-bus"
      ],
      "variables": [
        {
          "name": "EVENT_BUS_NAME",
          "source": "secret",
          "required": true
        },
        {
          "name": "EVENT_BUS_QUEUE_URL",
          "source": "secret",
          "required": true
        }
      ]
    },
    {
      "name": "api-cell",
      "description": "Reads Product API DNA and generates a dynamic Express + drizzle interpreter for all Marshall endpoints (intake, claimants, claims, evidence, firms, attorneys).",
      "dna": "torts/marshall/product.api",
      "adapter": {
        "type": "node/express",
        "config": {
          "core_dna": "torts/marshall/product.core",
          "port": 3001,
          "event_bus_engine": "eventbridge"
        }
      },
      "constructs": [
        "primary-db",
        "event-bus"
      ],
      "variables": [
        {
          "name": "DATABASE_URL",
          "source": "secret",
          "required": true
        },
        {
          "name": "EVENT_BUS_NAME",
          "source": "secret",
          "required": false
        },
        {
          "name": "JWT_SECRET",
          "source": "secret",
          "description": "Secret key for signing built-in JWT tokens.",
          "required": true
        }
      ],
      "outputs": [
        {
          "name": "api_url",
          "cell": "api-cell",
          "value": "http://localhost:3001"
        }
      ]
    },
    {
      "name": "admin-ui-cell",
      "description": "Marshall Fire staff admin SPA — Vite + React with the universal layout. Renders the intake queue, claimants, claims, evidence, firms, and attorneys against the Marshall API.",
      "dna": "torts/marshall/product.admin.ui",
      "adapter": {
        "type": "vite/react",
        "version": "5",
        "config": {
          "core_dna": "torts/marshall/product.core",
          "api_dna": "torts/marshall/product.api",
          "api_base": "http://localhost:3001",
          "port": 5174
        }
      },
      "constructs": [],
      "variables": []
    }
  ]
}
