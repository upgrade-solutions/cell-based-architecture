{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dna.local/product/web/layout",
  "title": "Layout",
  "description": "A Layout is the structural shell a set of Pages lives within. It defines the top-level UI frame: sidebar, full-width, split-panel, etc.",
  "type": "object",
  "required": ["name", "type"],
  "properties": {
    "name": {
      "type": "string",
      "description": "The PascalCase name of the layout.",
      "examples": ["AdminLayout", "PublicLayout", "DashboardLayout"]
    },
    "type": {
      "type": "string",
      "description": "The structural type of the layout.",
      "enum": ["sidebar", "full-width", "split-panel", "centered", "blank", "universal"]
    },
    "description": {
      "type": "string",
      "description": "A human-readable explanation of when and how this layout is used."
    },
    "features": {
      "type": "object",
      "description": "Feature flags controlling which chrome elements appear in the layout shell.",
      "properties": {
        "sidebar": { "type": "boolean" },
        "profileDropdown": { "type": "boolean" },
        "tenantPicker": { "type": "boolean" },
        "themeToggle": { "type": "boolean" }
      }
    },
    "tenants": {
      "type": "array",
      "description": "Available tenants/organizations for the tenant picker. First entry is the default.",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" }
        }
      }
    },
    "navigation": {
      "type": "array",
      "description": "Hierarchical sidebar navigation structure. Each item is either a nav group with children or a direct nav link. When omitted, the sidebar falls back to a flat list derived from routes. Group labels must be unique.",
      "items": {
        "type": "object",
        "required": ["label"],
        "properties": {
          "label": {
            "type": "string",
            "description": "Display label for the group header or direct link."
          },
          "icon": {
            "type": "string",
            "description": "Optional Unicode character or emoji used as the nav item icon."
          },
          "route": {
            "type": "string",
            "description": "If present, this item is a direct link (no children). Must match a path in routes."
          },
          "children": {
            "type": "array",
            "description": "Child nav items within this group.",
            "items": {
              "type": "object",
              "required": ["route", "label"],
              "properties": {
                "route": {
                  "type": "string",
                  "description": "Path matching a route in the routes array."
                },
                "label": {
                  "type": "string",
                  "description": "Display label for this nav link."
                },
                "icon": {
                  "type": "string",
                  "description": "Optional Unicode character or emoji."
                }
              }
            }
          }
        }
      }
    },
    "theme": {
      "type": "object",
      "description": "Visual theme configuration for white-labeling. Colors map to CSS custom properties consumed by Tailwind utilities. When omitted, a sensible default theme is generated.",
      "properties": {
        "colors": {
          "type": "object",
          "description": "Light mode color palette.",
          "properties": {
            "background": { "type": "string" },
            "foreground": { "type": "string" },
            "primary": { "type": "string" },
            "primary-foreground": { "type": "string" },
            "secondary": { "type": "string" },
            "secondary-foreground": { "type": "string" },
            "muted": { "type": "string" },
            "muted-foreground": { "type": "string" },
            "accent": { "type": "string" },
            "accent-foreground": { "type": "string" },
            "destructive": { "type": "string" },
            "destructive-foreground": { "type": "string" },
            "border": { "type": "string" },
            "input": { "type": "string" },
            "ring": { "type": "string" },
            "card": { "type": "string" },
            "card-foreground": { "type": "string" },
            "popover": { "type": "string" },
            "popover-foreground": { "type": "string" },
            "sidebar-background": { "type": "string" },
            "sidebar-foreground": { "type": "string" },
            "sidebar-border": { "type": "string" },
            "sidebar-accent": { "type": "string" },
            "sidebar-accent-foreground": { "type": "string" }
          }
        },
        "dark": {
          "type": "object",
          "description": "Dark mode color overrides. Same shape as colors."
        },
        "radius": {
          "type": "string",
          "description": "Base border radius. Derived sizes (sm, md, lg, xl) are calculated from this.",
          "default": "0.5rem"
        },
        "font": {
          "type": "string",
          "description": "Font family stack.",
          "default": "system-ui, sans-serif"
        }
      }
    },
    "pages": {
      "type": "array",
      "description": "The Page names that use this layout.",
      "items": { "type": "string" },
      "examples": [["LoanList", "LoanDetail", "LoanApply"], ["Login", "Register"]]
    }
  }
}
