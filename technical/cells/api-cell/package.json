{
  "name": "@dna-codes/cells-api",
  "version": "0.1.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "test": "node --experimental-vm-modules ../../../node_modules/.bin/jest",
    "test:fastify-build": "node --experimental-vm-modules ../../../node_modules/.bin/jest --config jest.fastify-build.config.js",
    "generate": "ts-node -r tsconfig-paths/register src/index.ts",
    "generate:lending": "ts-node -r tsconfig-paths/register src/index.ts ../../../dna/lending/technical.json api-cell ../../../output/lending-api",
    "generate:lending-nestjs": "ts-node -r tsconfig-paths/register src/index.ts ../../../dna/lending/technical.json api-cell-nestjs ../../../output/lending-api-nestjs",
    "generate:lending-rails": "ts-node -r tsconfig-paths/register src/index.ts ../../../dna/lending/technical.json api-cell-rails ../../../output/lending-api-rails",
    "typecheck:lending": "npm run generate:lending && npm install --prefix ../../../output/lending-api && npx tsc --noEmit --project ../../../output/lending-api/tsconfig.json"
  },
  "dependencies": {
    "@dna-codes/dna-core": "file:../../../../dna/packages/core"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/dist/",
      "/test/fastify-conformance/"
    ],
    "moduleNameMapper": {
      "^@dna-codes/dna-core$": "<rootDir>/../../../node_modules/@dna-codes/dna-core/dist/index.js"
    }
  }
}
