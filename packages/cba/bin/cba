#!/usr/bin/env bash
# Entry point for the `cba` CLI.
# When consumed as a package, prefer the prebuilt dist/. In development,
# fall back to ts-node on src/ so there's no build step in the inner loop.
set -e
# Resolve symlinks so BASH_SOURCE points at the actual script location.
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  LINK_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$LINK_DIR/$SOURCE"
done
DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
CBA_ROOT="$(cd "$DIR/.." && pwd)"

# Prefer the prebuilt dist when present (consumed as a package).
if [ -f "$CBA_ROOT/dist/index.js" ]; then
  exec node "$CBA_ROOT/dist/index.js" "$@"
fi

# Dev fallback: run TypeScript source via ts-node.
find_ts_node() {
  local d="$1"
  while [ "$d" != "/" ]; do
    if [ -x "$d/node_modules/.bin/ts-node" ]; then
      echo "$d/node_modules/.bin/ts-node"
      return 0
    fi
    d="$(dirname "$d")"
  done
  return 1
}

TS_NODE="$(find_ts_node "$CBA_ROOT")"
if [ -z "$TS_NODE" ]; then
  echo "cba: no dist/ build and ts-node not found. Run 'npm run build' (or 'npm install' for dev)." >&2
  exit 1
fi

exec "$TS_NODE" --project "$CBA_ROOT/tsconfig.json" "$CBA_ROOT/src/index.ts" "$@"
