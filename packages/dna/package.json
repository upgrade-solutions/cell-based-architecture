{
  "name": "@dna/core",
  "version": "0.0.1",
  "description": "DNA — a JSON description language for business systems. This package ships the canonical JSON schemas for the three DNA layers (operational, product, technical) along with TypeScript bindings and a JSON-schema manifest. Framework-agnostic; consumed by cells, viewers, validators, and any other DNA-aware tooling.",
  "keywords": ["dna", "json-schema", "dsl", "business-modeling", "cell-based-architecture"],
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json",
    "./schemas/*": "./schemas/*"
  },
  "files": [
    "dist",
    "schemas",
    "docs",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --experimental-vm-modules ../../node_modules/.bin/jest --passWithNoTests"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testPathIgnorePatterns": ["/node_modules/", "/dist/"]
  }
}
