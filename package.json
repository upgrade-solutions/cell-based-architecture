{
  "name": "cell-based-architecture",
  "private": true,
  "workspaces": [
    "packages/*",
    "technical/cells/*"
  ],
  "scripts": {
    "cba": "cba",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces --if-present",
    "generate:lending": "npm run generate:lending --workspace=@cell/api-cell",
    "generate:lending-nestjs": "npm run generate:lending-nestjs --workspace=@cell/api-cell",
    "generate:lending-rails": "npm run generate:lending-rails --workspace=@cell/api-cell",
    "generate:lending-db": "npm run generate:lending --workspace=@cell/db-cell",
    "start:express": "cd output/lending-api && npx ts-node src/main.ts",
    "start:nestjs": "cd output/lending-api-nestjs && npx ts-node -r tsconfig-paths/register src/main.ts"
  },
  "dependencies": {
    "@dna-codes/core": "file:../dna/packages/core",
    "@dna-codes/schemas": "file:../dna/packages/schemas",
    "@dna-codes/input-text": "file:../dna/packages/input-text",
    "@dna-codes/output-openapi": "file:../dna/packages/output-openapi"
  },
  "overrides": {
    "@dna-codes/core": "file:../dna/packages/core",
    "@dna-codes/schemas": "file:../dna/packages/schemas",
    "@dna-codes/input-text": "file:../dna/packages/input-text",
    "@dna-codes/output-openapi": "file:../dna/packages/output-openapi"
  }
}
