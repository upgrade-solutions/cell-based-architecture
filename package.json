{
  "name": "cell-based-architecture",
  "private": true,
  "workspaces": [
    "packages/*",
    "technical/cells/*"
  ],
  "scripts": {
    "cba": "cba",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces --if-present",
    "generate:lending": "npm run generate:lending --workspace=@dna-codes/cells-api",
    "generate:lending-nestjs": "npm run generate:lending-nestjs --workspace=@dna-codes/cells-api",
    "generate:lending-rails": "npm run generate:lending-rails --workspace=@dna-codes/cells-api",
    "generate:lending-db": "npm run generate:lending --workspace=@dna-codes/cells-db",
    "start:express": "cd output/lending-api && npx ts-node src/main.ts",
    "start:nestjs": "cd output/lending-api-nestjs && npx ts-node -r tsconfig-paths/register src/main.ts"
  },
  "dependencies": {
    "@dna-codes/dna-core": "file:../dna/packages/core",
    "@dna-codes/dna-schemas": "file:../dna/packages/schemas",
    "@dna-codes/dna-input-text": "file:../dna/packages/input-text",
    "@dna-codes/dna-output-openapi": "file:../dna/packages/output-openapi"
  },
  "overrides": {
    "@dna-codes/dna-core": "file:../dna/packages/core",
    "@dna-codes/dna-schemas": "file:../dna/packages/schemas",
    "@dna-codes/dna-input-text": "file:../dna/packages/input-text",
    "@dna-codes/dna-output-openapi": "file:../dna/packages/output-openapi"
  }
}
