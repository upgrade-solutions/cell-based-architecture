{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dna.local/operational",
  "title": "OperationalDNA",
  "description": "A complete Operational DNA document for an application instance. Composes a domain hierarchy with the full behavior stack: capabilities, causes, rules, outcomes, lifecycles, and equations.",
  "type": "object",
  "required": ["domain"],
  "properties": {
    "domain": {
      "$ref": "https://dna.local/operational/domain",
      "description": "The root domain, containing the full nested hierarchy of subdomains and nouns."
    },
    "capabilities": {
      "type": "array",
      "description": "All Noun:Verb capability pairs defined in this domain.",
      "items": { "$ref": "https://dna.local/operational/capability" }
    },
    "causes": {
      "type": "array",
      "description": "What initiates each capability — user actions, schedules, webhooks, or chained capabilities.",
      "items": { "$ref": "https://dna.local/operational/cause" }
    },
    "rules": {
      "type": "array",
      "description": "Constraints on capabilities — who may perform them (access rules) and what conditions must be satisfied (condition rules).",
      "items": { "$ref": "https://dna.local/operational/rule" }
    },
    "outcomes": {
      "type": "array",
      "description": "State changes and side effects that result from each capability.",
      "items": { "$ref": "https://dna.local/operational/outcome" }
    },
    "lifecycles": {
      "type": "array",
      "description": "Valid sequences of capabilities across the life of each noun.",
      "items": { "$ref": "https://dna.local/operational/lifecycle" }
    },
    "equations": {
      "type": "array",
      "description": "Named, technology-agnostic computations that cannot be expressed as declarative Rules or Outcomes. Implemented concretely by Scripts in Technical DNA.",
      "items": { "$ref": "https://dna.local/operational/equation" }
    }
  },
  "examples": [
    {
      "domain": {
        "name": "acme",
        "path": "acme",
        "domains": [
          {
            "name": "finance",
            "path": "acme.finance",
            "domains": [
              {
                "name": "lending",
                "path": "acme.finance.lending",
                "nouns": [
                  {
                    "name": "Loan",
                    "attributes": [
                      { "name": "amount", "type": "number", "required": true },
                      { "name": "status", "type": "enum", "values": ["pending", "active", "repaid"] }
                    ],
                    "verbs": [
                      { "name": "Apply" },
                      { "name": "Approve" }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      },
      "capabilities": [
        { "noun": "Loan", "verb": "Apply", "name": "Loan.Apply" },
        { "noun": "Loan", "verb": "Approve", "name": "Loan.Approve" }
      ],
      "causes": [
        { "capability": "Loan.Apply", "source": "user" },
        { "capability": "Loan.Approve", "source": "user" }
      ],
      "rules": [
        { "capability": "Loan.Apply", "type": "access", "allow": [{ "role": "borrower" }] },
        { "capability": "Loan.Approve", "type": "access", "allow": [{ "role": "underwriter" }] },
        { "capability": "Loan.Approve", "type": "condition", "conditions": [{ "attribute": "loan.status", "operator": "eq", "value": "under_review" }] }
      ],
      "outcomes": [
        { "capability": "Loan.Apply", "changes": [{ "attribute": "loan.status", "set": "under_review" }] },
        { "capability": "Loan.Approve", "changes": [{ "attribute": "loan.status", "set": "active" }] }
      ],
      "lifecycles": [
        { "noun": "Loan", "steps": ["Loan.Apply", "Loan.Approve"] }
      ]
    }
  ]
}
