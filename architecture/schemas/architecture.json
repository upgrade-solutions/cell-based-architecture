{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dna.local/architecture",
  "title": "ArchitectureDNA",
  "description": "A complete Architecture DNA document for a domain. Contains named views that visualize platform architecture as interactive diagrams of nodes, connections, and zones. Each view represents a different perspective (deployment topology, data flow, domain map, etc.).",
  "type": "object",
  "required": ["views"],
  "properties": {
    "views": {
      "type": "array",
      "description": "The named diagram perspectives for this domain.",
      "minItems": 1,
      "items": { "$ref": "https://dna.local/architecture/view" }
    }
  },
  "examples": [
    {
      "views": [
        {
          "name": "deployment",
          "description": "Cell deployment topology with infrastructure",
          "layout": { "type": "hierarchical", "direction": "TB" },
          "nodes": [
            { "id": "api-cell", "name": "API Cell", "type": "cell", "source": "technical:cell:api-cell" },
            { "id": "primary-db", "name": "Primary DB", "type": "construct", "source": "technical:construct:primary-db" }
          ],
          "connections": [
            { "id": "api-to-db", "source": "api-cell", "target": "primary-db", "type": "depends-on" }
          ]
        }
      ]
    }
  ]
}
